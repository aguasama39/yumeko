{
  "name": "yumeko",
  "version": "1.0.4",
  "description": "Desktop BitTorrent client",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"wait-on dist-react/index.html && electron .\"",
    "start": "vite build && electron .",
    "dist": "vite build && electron-builder --win --x64",
    "dist:linux": "vite build && electron-builder --linux --x64"
  },
  "dependencies": {
    "webtorrent": "^2.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.torrent.app",
    "productName": "Yumeko",
    "directories": { "output": "dist" },
    "files": ["electron/**/*", "dist-react/**/*", "node_modules/**/*"],
    "asarUnpack": ["node_modules/**/*.node"],
    "npmRebuild": false,
    "win": {
      "icon": "assets/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Network"
    }
  }
}
